datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  Employee
  DepartmentHead
  AssetManager
  Admin
}

enum UserStatus {
  Active
  Inactive
}

enum AssetStatus {
  Available
  Allocated
  Reserved
  UnderMaintenance
  Lost
  Retired
  Disposed
}

enum AllocationStatus {
  Active
  Returned
  Overdue
}

enum TransferStatus {
  Requested
  Approved
  Rejected
  Reallocated
}

enum BookingStatus {
  Upcoming
  Ongoing
  Completed
  Cancelled
}

enum Priority {
  Low
  Medium
  High
  Critical
}

enum MaintenanceStatus {
  Pending
  Approved
  Rejected
  TechnicianAssigned
  InProgress
  Resolved
}

enum AuditStatus {
  Open
  Closed
}

enum AuditResult {
  Verified
  Missing
  Damaged
}

model User {
  id              Int        @id @default(autoincrement())
  name            String
  email           String     @unique
  passwordHash    String     @map("password_hash")
  departmentId    Int?       @map("department_id")
  role            Role       @default(Employee)
  status          UserStatus @default(Active)
  createdAt       DateTime   @default(now()) @map("created_at")
  resetToken      String?    @map("reset_token")
  resetTokenExpiry DateTime?  @map("reset_token_expiry")

  department      Department? @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  headedDepartment Department? @relation("DepartmentHead")

  allocations         Allocation[]
  heldAssets          Asset[]
  transfersFrom       TransferRequest[]    @relation("TransferFromHolder")
  transfersTo         TransferRequest[]    @relation("TransferToHolder")
  transfersRequested  TransferRequest[]    @relation("TransferRequestedBy")
  transfersApproved   TransferRequest[]    @relation("TransferApprovedBy")
  bookings            Booking[]
  maintenanceRaised   MaintenanceRequest[] @relation("MaintenanceRaisedBy")
  maintenanceApproved MaintenanceRequest[] @relation("MaintenanceApprovedBy")
  auditItems          AuditItem[]
  notifications       Notification[]
  activityLogs        ActivityLog[]

  @@map("users")
}

model Department {
  id                 Int        @id @default(autoincrement())
  name               String
  departmentHeadId   Int?       @unique @map("department_head_id")
  parentDepartmentId Int?       @map("parent_department_id")
  status             UserStatus @default(Active)

  departmentHead     User?      @relation("DepartmentHead", fields: [departmentHeadId], references: [id])
  parentDepartment   Department? @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  subDepartments     Department[] @relation("DepartmentHierarchy")
  employees          User[]     @relation("DepartmentEmployees")
  assets             Asset[]    @relation("DepartmentAssets")
  allocations        Allocation[]

  @@map("departments")
}

model AssetCategory {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  customFields Json?    @map("custom_fields")

  assets       Asset[]

  @@map("asset_categories")
}

model Asset {
  id                  Int          @id @default(autoincrement())
  name                String
  categoryId          Int          @map("category_id")
  assetTag            String       @unique @map("asset_tag")
  serialNumber        String       @map("serial_number")
  qrCode              String?      @map("qr_code")
  acquisitionDate     DateTime     @map("acquisition_date")
  acquisitionCost     Decimal      @map("acquisition_cost") @db.Decimal(10, 2)
  condition           String
  location            String
  photosDocs          Json?        @map("photos_docs")
  isBookable          Boolean      @default(false) @map("is_bookable")
  status              AssetStatus  @default(Available)
  currentHolderId     Int?         @map("current_holder_id")
  currentDepartmentId Int?         @map("current_department_id")

  category            AssetCategory @relation(fields: [categoryId], references: [id])
  currentHolder       User?        @relation(fields: [currentHolderId], references: [id])
  currentDepartment   Department?  @relation("DepartmentAssets", fields: [currentDepartmentId], references: [id])

  allocations         Allocation[]
  transferRequests    TransferRequest[]
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditItems          AuditItem[]

  @@map("assets")
}

model Allocation {
  id                   Int              @id @default(autoincrement())
  assetId              Int              @map("asset_id")
  employeeId           Int?             @map("employee_id")
  departmentId         Int?             @map("department_id")
  allocatedDate        DateTime         @default(now()) @map("allocated_date")
  expectedReturnDate   DateTime         @map("expected_return_date")
  actualReturnDate     DateTime?        @map("actual_return_date")
  returnConditionNotes String?          @map("return_condition_notes")
  status               AllocationStatus @default(Active)

  asset                Asset            @relation(fields: [assetId], references: [id])
  employee             User?            @relation(fields: [employeeId], references: [id])
  department           Department?      @relation(fields: [departmentId], references: [id])

  @@map("allocations")
}

model TransferRequest {
  id            Int            @id @default(autoincrement())
  assetId       Int            @map("asset_id")
  fromHolderId  Int?           @map("from_holder_id")
  toHolderId    Int            @map("to_holder_id")
  status        TransferStatus @default(Requested)
  requestedById Int            @map("requested_by_id")
  approvedById  Int?           @map("approved_by_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  asset         Asset          @relation(fields: [assetId], references: [id])
  fromHolder    User?          @relation("TransferFromHolder", fields: [fromHolderId], references: [id])
  toHolder      User           @relation("TransferToHolder", fields: [toHolderId], references: [id])
  requestedBy   User           @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  approvedBy    User?          @relation("TransferApprovedBy", fields: [approvedById], references: [id])

  @@map("transfer_requests")
}

model Booking {
  id              Int           @id @default(autoincrement())
  resourceAssetId Int           @map("resource_asset_id")
  bookedById      Int           @map("booked_by_id")
  startTime       DateTime      @map("start_time")
  endTime         DateTime      @map("end_time")
  status          BookingStatus @default(Upcoming)
  createdAt       DateTime      @default(now()) @map("created_at")

  asset           Asset         @relation(fields: [resourceAssetId], references: [id])
  bookedBy        User          @relation(fields: [bookedById], references: [id])

  @@map("bookings")
}

model MaintenanceRequest {
  id                 Int               @id @default(autoincrement())
  assetId            Int               @map("asset_id")
  raisedById         Int               @map("raised_by_id")
  issueDescription   String            @map("issue_description")
  priority           Priority          @default(Medium)
  photo              String?
  status             MaintenanceStatus @default(Pending)
  assignedTechnician String?           @map("assigned_technician")
  approvedById       Int?              @map("approved_by_id")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  asset              Asset             @relation(fields: [assetId], references: [id])
  raisedBy           User              @relation("MaintenanceRaisedBy", fields: [raisedById], references: [id])
  approvedBy         User?             @relation("MaintenanceApprovedBy", fields: [approvedById], references: [id])

  @@map("maintenance_requests")
}

model AuditCycle {
  id                 Int         @id @default(autoincrement())
  name               String
  scopeDepartmentId  Int?        @map("scope_department_id")
  location           String?
  dateRangeStart     DateTime    @map("date_range_start")
  dateRangeEnd       DateTime    @map("date_range_end")
  status             AuditStatus @default(Open)
  assignedAuditors   Json?       @map("assigned_auditors")

  auditItems         AuditItem[]

  @@map("audit_cycles")
}

model AuditItem {
  id           Int         @id @default(autoincrement())
  auditCycleId Int         @map("audit_cycle_id")
  assetId      Int         @map("asset_id")
  result       AuditResult
  notes        String?
  auditorId    Int         @map("auditor_id")

  auditCycle   AuditCycle  @relation(fields: [auditCycleId], references: [id])
  asset        Asset       @relation(fields: [assetId], references: [id])
  auditor      User        @relation(fields: [auditorId], references: [id])

  @@map("audit_items")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   Int      @map("entity_id")
  timestamp  DateTime @default(now())
  details    Json?

  user       User     @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}
